# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
tests/screenshots/*.png

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all except the committed template
.env*
!.env.example

# local notes / scratch
fijifish_clerk.xlsx
*.xlsx
.env.txt

# office temp files
~$*

# playwright session logs
.playwright-mcp/

# pdf/docx design artefacts (not source)
*.pdf
*.docx

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
