# FijiFish — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real secrets.
#
# All NEXT_PUBLIC_* vars are exposed to the browser. Everything else is server-only.
#
# Placeholders deliberately avoid the `sk_test_...` / `pk_test_...` / `whsec_...`
# prefixes so GitHub push protection does not flag this template file.

# ---------- Clerk (auth, 4 roles) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>
# Webhook secret from Clerk dashboard, used by /api/webhooks/clerk (svix signature check)
CLERK_WEBHOOK_SECRET=<your-clerk-webhook-secret>
# Redirect URLs after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---------- Supabase (AU region, data + storage + realtime) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# SERVER ONLY. Never use on client — bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ---------- Stripe (AUD, AU buyers only) ----------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ---------- Twilio (SMS + WhatsApp notifications + broadcasts) ----------
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=+61xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+61xxxxxxxxx

# ---------- Mapbox (dark map tiles, route optimisation, geocoding) ----------
NEXT_PUBLIC_MAPBOX_TOKEN=<your-mapbox-token>

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
